# GoHighLevel Private Integration credentials
#
# 1. Copy this file:   cp config/ghl.env.example config/ghl.env
# 2. Fill in your values below. ghl.env is gitignored: the token stays on your machine.
#
# Where to get a token: GHL sub-account -> Settings -> Private Integrations -> New
# (read scopes for contacts are enough for pulling)

GHL_PIT=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=your-subaccount-location-id
